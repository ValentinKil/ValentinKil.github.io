<div class="row" style="margin-bottom: 1rem;">
  <div id="{{ entry.key }}" class="col-sm-12">
    
    <h3 class="archive__item-title" style="font-size: 1.25rem; margin-bottom: 0.25rem;">
      
      {% if entry.url %}
        <a href="{{ entry.url }}"><i class="fas fa-fw fa-link zoom" aria-hidden="true" style="font-size: 0.9rem; margin-right: 5px;"></i></a>
      {% endif %}
      
      {% if entry.pdf %}
        <a href="{% if entry.pdf contains '://' %}{{ entry.pdf }}{% else %}{{ entry.pdf | prepend: '/assets/pdf/' | relative_url }}{% endif %}" class="special-link">
          <i class="fas fa-fw fa-file-pdf zoom" aria-hidden="true" style="font-size: 0.9rem; margin-right: 5px; color: #e74c3c;"></i>
        </a>
      {% endif %}
      
      {% if entry.code %}
        <a href="{{ entry.code }}" class="special-link">
          <i class="fab fa-fw fa-github zoom" aria-hidden="true" style="font-size: 0.9rem; margin-right: 5px; color: #333;"></i>
        </a>
      {% endif %}

      {% if entry.arxiv %}
        <a href="http://arxiv.org/abs/{{ entry.arxiv }}" class="special-link">
          <i class="fas fa-fw fa-bold zoom" aria-hidden="true" style="font-size: 0.9rem; margin-right: 5px; color: #b31b1b;"></i>
        </a>
      {% endif %}

      {% if entry.url %}
        <a href="{{ entry.url }}">{{ entry.title }}</a>
      {% elsif entry.pdf %}
        <a href="{{ entry.pdf | relative_url }}">{{ entry.title }}</a>
      {% else %}
        {{ entry.title }}
      {% endif %}
    </h3>

    <div class="archive__item-excerpt" style="font-size: 0.95rem; margin-bottom: 0.25rem;">
      {%- for author in entry.author_array -%}
        {% assign author_is_self = false %}
        {% if site.scholar.last_name contains author.last and site.scholar.first_name contains author.first %}
          {% assign author_is_self = true %}
        {% endif %}

        {% if forloop.first == false %}, {% endif %}
        {% if forloop.last and forloop.length > 1 %}and {% endif %}
        
        {% if author_is_self %}
          <strong>{{ author.first }} {{ author.last }}</strong>
        {% else %}
          {{ author.first }} {{ author.last }}
        {% endif %}
      {%- endfor -%}
    </div>

    <div class="periodical" style="font-size: 0.9rem; color: #666; font-style: italic;">
      {% if entry.type == 'article' %}
        {{ entry.journal }}
      {% elsif entry.booktitle %}
        In {{ entry.booktitle }}
      {% endif %}
      {% if entry.year %}
        ({{ entry.year }})
      {% endif %}
    </div>

    {% if entry.abstract %}
      <div class="links" style="margin-top: 5px;">
        <a class="abstract btn btn-sm z-depth-0" role="button" style="border: 1px solid #ddd; padding: 2px 8px; font-size: 0.75rem;">Abstract</a>
      </div>
      <div class="abstract hidden" style="font-size: 0.85rem; background: #f9f9f9; padding: 10px; margin-top: 5px; border-radius: 5px;">
        {{ entry.abstract }}
      </div>
    {% endif %}

  </div>
</div>